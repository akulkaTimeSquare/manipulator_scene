        <geom type="box" pos="0 -0.132 0.29" size="0.12 0.008 0.29" material="mat_cabinet"/>
        <geom type="box" pos="0.112 0 0.29" size="0.008 0.132 0.29" material="mat_cabinet"/>
        <geom type="box" pos="0 0 0.585" size="0.12 0.132 0.008" material="mat_cabinet"/>
        <geom type="box" pos="0 0 0.08" size="0.106 0.124 0.006" material="shelf_red"/>
        <geom type="box" pos="0 0 0.18" size="0.106 0.124 0.006" material="shelf_green"/>
        <geom type="box" pos="0 0 0.28" size="0.106 0.124 0.006" material="shelf_blue"/>
        <geom type="box" pos="0 0 0.38" size="0.106 0.124 0.006" material="shelf_yellow"/>
        <geom type="box" pos="0 0 0.48" size="0.106 0.124 0.006" material="shelf_orange"/>
        <geom type="box" pos="0.104 0 0.13" size="0.0025 0.122 0.044" material="shelf_red"/>
        <geom type="box" pos="0.104 0 0.23" size="0.0025 0.122 0.044" material="shelf_green"/>
        <geom type="box" pos="0.104 0 0.33" size="0.0025 0.122 0.044" material="shelf_blue"/>
        <geom type="box" pos="0.104 0 0.43" size="0.0025 0.122 0.044" material="shelf_yellow"/>
        <geom type="box" pos="0.104 0 0.53" size="0.0025 0.122 0.044" material="shelf_orange"/>
      </body>
    </body>

    <body name="cube_red_1" pos="-0.31 -0.23 0.835">
      <freejoint/>
      <geom type="box" size="0.018 0.018 0.018" material="cube_red"/>
