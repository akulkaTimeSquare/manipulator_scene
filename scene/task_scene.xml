              <geom type="capsule" fromto="0 0 0 0.21 0 0" size="0.023" material="mat_robot"/>

              <body name="wrist_pitch" pos="0.21 0 0">
                <joint name="j4" type="hinge" axis="0 1 0" range="-160 160"/>
                <geom type="capsule" fromto="0 0 0 0.08 0 0" size="0.02" material="mat_robot"/>

                <body name="wrist_roll" pos="0.08 0 0">
                  <joint name="j5" type="hinge" axis="1 0 0" range="-180 180"/>
                  <geom type="sphere" size="0.03" material="mat_robot"/>
                  <geom type="capsule" fromto="0 0 0 0 0.06 0" size="0.004" material="shelf_orange"/>

                  <body name="ee" pos="0.04 0 0">
                    <geom type="box" size="0.026 0.02 0.016" material="mat_gripper"/>
                    <geom type="box" pos="0.014 0.013 0" size="0.012 0.0035 0.014" material="mat_gripper"/>
                    <geom type="box" pos="0.014 -0.013 0" size="0.012 0.0035 0.014" material="mat_gripper"/>
                    <geom type="box" pos="0.018 0.016 0" size="0.006 0.002 0.011" material="mat_gripper"/>
                    <geom type="box" pos="0.018 -0.016 0" size="0.006 0.002 0.011" material="mat_gripper"/>
                    <geom type="box" pos="0.01 0 0.025" size="0.0028 0.0028 0.011" material="mat_camera"/>
                    <body name="grip_cam_mount" pos="0.012 0 0.038">
                      <geom type="box" pos="-0.002 0 0" size="0.004 0.006 0.005" material="mat_camera"/>
                      <geom type="box" pos="0.006 0 0.010" size="0.008 0.011 0.006" euler="0 24 0" material="mat_camera"/>
                      <geom type="capsule" fromto="0.003 0 0.010 -0.006 0 0.014" size="0.0022" material="mat_lens"/>
                      <camera name="grip_cam" pos="0.002 0 0.010" zaxis="-1 0 0.42" fovy="72"/>
                    </body>

                    <body name="left_finger" pos="0.035 0.018 0">
                      <joint name="finger_left" type="hinge" axis="0 0 -1" range="-45 30" damping="0.35"/>
                      <geom type="box" pos="0.024 0 0" size="0.022 0.0038 0.014" material="mat_gripper"/>
                    </body>

                    <body name="right_finger" pos="0.035 -0.018 0">
                      <joint name="finger_right" type="hinge" axis="0 0 1" range="-45 30" damping="0.35"/>
                      <geom type="box" pos="0.024 0 0" size="0.022 0.0038 0.014" material="mat_gripper"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>

      <body name="basket" pos="-0.34 -0.27 0.78">
        <geom type="box" pos="0 0 0.01" size="0.11 0.09 0.01" material="mat_basket"/>
        <geom type="box" pos="0.11 0 0.04" size="0.01 0.09 0.04" material="mat_basket"/>
