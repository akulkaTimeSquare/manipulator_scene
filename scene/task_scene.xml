<mujoco model="mini_sorting_scene">
  <compiler angle="degree" autolimits="true"/>
  <option gravity="0 0 -9.81" integrator="RK4" timestep="0.002"/>

  <visual>
    <headlight ambient="0.35 0.35 0.35" diffuse="0.7 0.7 0.7" specular="0.15 0.15 0.15"/>
    <rgba haze="0.95 0.97 1.0 1"/>
  </visual>

  <asset>
    <texture name="sky_bg" type="skybox" builtin="gradient" width="512" height="512"
             rgb1="0.86 0.92 0.98" rgb2="0.98 0.99 1.0"/>
    <material name="mat_ground" rgba="0.90 0.91 0.92 1" reflectance="0.02"/>

    <material name="mat_table" rgba="0.72 0.58 0.42 1"/>
    <material name="mat_robot" rgba="0.25 0.3 0.35 1"/>
    <material name="mat_gripper" rgba="0.18 0.18 0.2 1"/>
    <material name="mat_camera" rgba="0.08 0.08 0.09 1"/>
    <material name="mat_lens" rgba="0.12 0.24 0.32 1"/>
    <material name="mat_basket" rgba="0.3 0.2 0.12 1"/>
    <material name="mat_cabinet" rgba="0.22 0.22 0.24 1"/>

    <material name="shelf_red" rgba="0.9 0.25 0.25 1"/>
    <material name="shelf_green" rgba="0.25 0.75 0.35 1"/>
    <material name="shelf_blue" rgba="0.22 0.45 0.9 1"/>
    <material name="shelf_yellow" rgba="0.95 0.83 0.25 1"/>
    <material name="shelf_orange" rgba="0.94 0.5 0.2 1"/>
    <material name="shelf_purple" rgba="0.62 0.36 0.86 1"/>

    <material name="cube_red" rgba="0.92 0.2 0.2 1"/>
    <material name="cube_green" rgba="0.22 0.82 0.3 1"/>
    <material name="cube_blue" rgba="0.18 0.45 0.95 1"/>
    <material name="cube_yellow" rgba="0.96 0.86 0.28 1"/>
    <material name="cube_orange" rgba="0.95 0.5 0.15 1"/>
  </asset>

  <default>
    <joint damping="2.2" armature="0.02"/>
    <geom condim="4" friction="0.9 0.05 0.01" solref="0.01 1" solimp="0.9 0.97 0.001"/>
    <motor ctrllimited="true" ctrlrange="-1 1"/>
  </default>

  <worldbody>
    <light name="key_light" pos="0.2 -0.1 2.2" dir="0 0 -1" directional="true" castshadow="true"/>

    <geom name="floor" type="plane" size="4 4 0.1" material="mat_ground"/>

    <body name="table" pos="0 0 0">
      <geom name="table_top" type="box" pos="0 0 0.76" size="0.52 0.40 0.02" material="mat_table"/>
      <geom type="box" pos="0.46 0.34 0.38" size="0.03 0.03 0.38" material="mat_table"/>
      <geom type="box" pos="0.46 -0.34 0.38" size="0.03 0.03 0.38" material="mat_table"/>
      <geom type="box" pos="-0.46 0.34 0.38" size="0.03 0.03 0.38" material="mat_table"/>
      <geom type="box" pos="-0.46 -0.34 0.38" size="0.03 0.03 0.38" material="mat_table"/>

      <body name="robot_base" pos="-0.28 0.0 0.78">
        <geom type="cylinder" size="0.055 0.03" material="mat_robot"/>

        <body name="shoulder_yaw" pos="0 0 0.03">
          <joint name="j1" type="hinge" axis="0 0 1" range="-180 180"/>
          <geom type="capsule" fromto="0 0 0 0 0 0.17" size="0.035" material="mat_robot"/>

          <body name="shoulder_pitch" pos="0 0 0.17">
            <joint name="j2" type="hinge" axis="0 1 0" range="-135 135"/>
            <geom type="capsule" fromto="0 0 0 0.24 0 0" size="0.028" material="mat_robot"/>

            <body name="elbow_pitch" pos="0.24 0 0">
