  <actuator>
    <motor name="a_j1" joint="j1" gear="65"/>
    <motor name="a_j2" joint="j2" gear="75"/>
    <motor name="a_j3" joint="j3" gear="70"/>
    <motor name="a_j4" joint="j4" gear="50"/>
    <motor name="a_j5" joint="j5" gear="35"/>
    <position name="a_fl" joint="finger_left" kp="360" ctrlrange="-0.79 0.52" ctrllimited="true"/>
    <position name="a_fr" joint="finger_right" kp="360" ctrlrange="-0.79 0.52" ctrllimited="true"/>
  </actuator>
